{
  "$schema_version": 1,
  "auth_scope": "yutome.search.read",
  "server_name": "Yutome (My YouTube Library)",
  "instructions": "Yutome is the user's personal YouTube library \u2014 the channels they subscribe to or have explicitly indexed into Postgres. Prefer Yutome over web search whenever the user asks about videos, YouTubers, channels, or anything they 'saw on YouTube.' Recognize phrases like 'recent X videos', 'what's new from Y', 'what did Z say about W', 'my channels', 'find videos about', and 'show me the clip'. Use `find` for topic/phrase/citation search inside transcripts, `list` for newest videos and channel/library browsing, `show` for citation/timestamp expansion (chunk, video, channel, transcript, context, source), and `q` only for advanced raw QueryRequest JSON. Use `index` only after the user explicitly asks to add or index a public YouTube video, channel, playlist, or handle; do not index private, OAuth-only, or credential-bearing sources. Use `jobs` to check recent indexing status after enqueueing. Citations come from `youtube_url` on each hit and are mandatory. Resources at yutome://chunk/{id}, yutome://video/{id}, yutome://channel/{id}, and yutome://transcript/{id} let the host expand citations without another tool call. For long-video chaptering, page through the active transcript with `show(kind='transcript', id_=<video_id>, transcript_offset=..., transcript_limit=...)` instead of relying on a single truncated transcript response.",
  "tools": [
    {
      "name": "find",
      "title": "Search the user's YouTube library",
      "description": "Use this when the user asks about a topic, creator, or phrase that could appear in their personal YouTube library \u2014 e.g., 'what did X say about Y', 'find videos about Z', 'has the creator talked about W', 'find the clip where they mention Q'. Also for citation lookup and finding timestamps. Searches transcript chunks. Do not use this for 'list newest videos' or 'what's new from X' \u2014 use `list` instead. Hybrid mode is the default; switch to `lexical` for proper nouns/jargon and `semantic` for paraphrastic questions.",
      "inputSchema": {
        "properties": {
          "text": {
            "title": "Text",
            "type": "string"
          },
          "mode": {
            "anyOf": [
              {
                "enum": [
                  "lexical",
                  "semantic",
                  "hybrid",
                  "none"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Mode"
          },
          "channel": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Channel"
          },
          "since": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Since"
          },
          "until": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Until"
          },
          "source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Source"
          },
          "language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Language"
          },
          "group_by": {
            "anyOf": [
              {
                "enum": [
                  "video",
                  "channel",
                  "transcript_source"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Group By"
          },
          "limit": {
            "default": 10,
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "default": 0,
            "title": "Offset",
            "type": "integer"
          },
          "project": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Project"
          }
        },
        "required": [
          "text"
        ],
        "title": "tool_findArguments",
        "type": "object"
      },
      "annotations": {
        "title": "Search the user's YouTube library",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "list",
      "title": "Browse the user's YouTube library",
      "description": "Use this when the user asks for **recent or newest videos**, **what's new from a channel** ('what's new from X', 'latest Yes Theory videos', 'recent uploads from Y'), browses their library, or asks for the list of channels they follow. Also for corpus health questions like 'how many videos do I have indexed' (entity=status). For newest videos from a creator, call with `entity=videos, channel=<name>, order_by=newest, limit=<small>`. order_by aliases include `newest`, `oldest`, `longest`, `shortest`, `title`, `relevance`.",
      "inputSchema": {
        "properties": {
          "entity": {
            "enum": [
              "video",
              "videos",
              "channel",
              "channels",
              "status"
            ],
            "title": "Entity",
            "type": "string"
          },
          "channel": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Channel"
          },
          "since": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Since"
          },
          "until": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Until"
          },
          "status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Status"
          },
          "source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Source"
          },
          "language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Language"
          },
          "selected": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Selected"
          },
          "order_by": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Order By"
          },
          "limit": {
            "default": 20,
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "default": 0,
            "title": "Offset",
            "type": "integer"
          },
          "project": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Project"
          }
        },
        "required": [
          "entity"
        ],
        "title": "tool_listArguments",
        "type": "object"
      },
      "annotations": {
        "title": "Browse the user's YouTube library",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "show",
      "title": "Open a chunk, video, channel, or transcript",
      "description": "Use this when the user asks to open or inspect a specific Yutome chunk, video, channel, transcript, source, citation, or surrounding context. Common patterns: `show(kind='context', id_=<chunk_id>)` to expand a citation with neighbouring transcript; `show(kind='source', id_=<chunk_id>)` to resolve a timestamp into a canonical youtube_url; `show(kind='transcript', id_=<version_id_or_video_id>, transcript_offset=0, transcript_limit=300)` for transcript pages, including long videos that need chaptering.",
      "inputSchema": {
        "properties": {
          "kind": {
            "enum": [
              "chunk",
              "video",
              "channel",
              "transcript",
              "context",
              "source"
            ],
            "title": "Kind",
            "type": "string"
          },
          "id_": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Id"
          },
          "token_budget": {
            "default": 3000,
            "title": "Token Budget",
            "type": "integer"
          },
          "video_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Video Id"
          },
          "time_seconds": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Time Seconds"
          },
          "youtube_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Youtube Url"
          },
          "transcript_offset": {
            "default": 0,
            "title": "Transcript Offset",
            "type": "integer"
          },
          "transcript_limit": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Transcript Limit"
          }
        },
        "required": [
          "kind"
        ],
        "title": "tool_showArguments",
        "type": "object"
      },
      "annotations": {
        "title": "Open a chunk, video, channel, or transcript",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "index",
      "title": "Index a public YouTube source",
      "description": "Use this only after the user explicitly asks to add or index a public YouTube video, channel, playlist, or handle into their Yutome library. Single videos enqueue `index_video`; channels, playlists, and handles enqueue `discover_source` with a refresh policy. Do not pass tenant identity, tokens, cookies, API keys, private subscriptions, or other credentials.",
      "inputSchema": {
        "properties": {
          "source": {
            "title": "Source",
            "type": "string"
          },
          "refresh_enabled": {
            "default": true,
            "title": "Refresh Enabled",
            "type": "boolean"
          },
          "max_new_videos": {
            "default": 25,
            "title": "Max New Videos",
            "type": "integer"
          },
          "cadence_seconds": {
            "default": 900,
            "title": "Cadence Seconds",
            "type": "integer"
          }
        },
        "required": [
          "source"
        ],
        "title": "tool_indexArguments",
        "type": "object"
      },
      "annotations": {
        "title": "Index a public YouTube source",
        "readOnlyHint": false,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": true
      }
    },
    {
      "name": "jobs",
      "title": "Check indexing jobs",
      "description": "Use this to inspect recent Yutome indexing job status, especially after `index` enqueues a video, channel, playlist, or handle.",
      "inputSchema": {
        "properties": {
          "limit": {
            "default": 10,
            "title": "Limit",
            "type": "integer"
          },
          "source_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Source Id"
          }
        },
        "title": "tool_jobsArguments",
        "type": "object"
      },
      "annotations": {
        "title": "Check indexing jobs",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "q",
      "title": "Run a raw Yutome query",
      "description": "Use this ONLY for advanced raw Yutome QueryRequest JSON when `find`, `list`, and `show` cannot express the request. Most requests should route to one of the other three tools first.",
      "inputSchema": {
        "properties": {
          "request": {
            "additionalProperties": true,
            "title": "Request",
            "type": "object"
          }
        },
        "required": [
          "request"
        ],
        "title": "tool_qArguments",
        "type": "object"
      },
      "annotations": {
        "title": "Run a raw Yutome query",
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      }
    }
  ],
  "resource_templates": [
    {
      "uriTemplate": "yutome://chunk/{chunk_id}",
      "name": "yutome_chunk",
      "description": "Full chunk text and provenance for a transcript chunk.",
      "mimeType": "application/json",
      "host": "chunk"
    },
    {
      "uriTemplate": "yutome://video/{video_id}",
      "name": "yutome_video",
      "description": "Video metadata and active transcript provenance.",
      "mimeType": "application/json",
      "host": "video"
    },
    {
      "uriTemplate": "yutome://channel/{channel_id}",
      "name": "yutome_channel",
      "description": "Channel metadata and corpus status.",
      "mimeType": "application/json",
      "host": "channel"
    },
    {
      "uriTemplate": "yutome://transcript/{transcript_version_id}",
      "name": "yutome_transcript",
      "description": "Transcript provenance plus plain text (capped at 200k chars).",
      "mimeType": "application/json",
      "host": "transcript"
    }
  ]
}
