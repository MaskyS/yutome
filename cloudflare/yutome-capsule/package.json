{
  "name": "yutome-capsule",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker for yutome's remote MCP endpoint. Tools and resources come from the Python contract registry via src/contract.json.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "test:ts": "tsc -p tsconfig.test.json --noEmit && node --test --experimental-strip-types --experimental-specifier-resolution=node test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.13.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250612.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.93.0"
  }
}
