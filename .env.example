# Local secrets and proxy configuration. Copy to .env; .env is ignored.

# Voyage embeddings.
VOYAGE_API_KEY=

# Generic HTTP/SOCKS proxy used by youtube-transcript-api and yt-dlp.
# Examples:
# YTKB_PROXY_URLS=http://user:pass@host1:port,socks5://user:pass@host2:port
# YTKB_HTTP_PROXY=http://user:pass@host:port
# YTKB_HTTPS_PROXY=http://user:pass@host:port

# Webshare rotating residential proxy config for youtube-transcript-api and yt-dlp.
# YTKB_WEBSHARE_USERNAME=
# YTKB_WEBSHARE_PASSWORD=
# YTKB_WEBSHARE_DOMAIN=p.webshare.io
# YTKB_WEBSHARE_PORT=80

# Gemini fallback. GEMINI_API_KEY or GOOGLE_API_KEY is read by the google-genai client.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
